# ============================================================
# Raio-X da Aquisição B2B — variáveis de ambiente
# Copie este arquivo para .env.local e preencha os valores.
# ============================================================

# URL pública da aplicação (usada para montar o link do PDF enviado no WhatsApp).
# Desenvolvimento: http://localhost:3000  |  Produção: https://seu-dominio.vercel.app
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ----- Banco de dados (Postgres do cliente) — Fase 4 -----
DATABASE_URL="postgresql://usuario:senha@host:5432/banco?schema=public"

# ----- WhatsApp Cloud API (Meta) — Fase 6 -----
# Token de acesso permanente (System User).
WHATSAPP_ACCESS_TOKEN=""
# Phone Number ID do número no WhatsApp Business.
WHATSAPP_PHONE_NUMBER_ID=""
# Nome do template utility aprovado na Meta (ex.: raio_x_resultado).
WHATSAPP_TEMPLATE_NAME="raio_x_resultado"
# Versão da Graph API (opcional; o código usa um padrão se vazio).
WHATSAPP_API_VERSION="v21.0"
# Idioma do template aprovado na Meta.
WHATSAPP_TEMPLATE_LANG="pt_BR"

# ----- WhatsApp: TRAVAS DE SEGURANÇA (tudo OFF por padrão) -----
# Liga o ENVIO REAL. Deixe "false" até testar tudo. Sem isto, nada é enviado.
WHATSAPP_ENABLED="false"
# Allowlist de teste (E.164, vírgula). SÓ estes números recebem. Ex.: "5511999999999"
WHATSAPP_ALLOWLIST=""
# Libera envio para TODOS (produção). Só ligue após validar com o seu número.
WHATSAPP_ALLOW_ALL="false"
# App Secret (Meta) — verifica a assinatura do webhook. Sem ele, o webhook REJEITA tudo.
WHATSAPP_APP_SECRET=""
# Verify token do webhook (você inventa um valor e repete no painel da Meta).
WHATSAPP_VERIFY_TOKEN=""

# ----- Postgres: SSL -----
# "require" (padrão, p/ bancos gerenciados) ou "disable" (Postgres local sem SSL).
DATABASE_SSL="require"
